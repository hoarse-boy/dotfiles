## kitty
# kitty session files
kitty/.config/kitty/sessions/*
stow/kitty/.config/kitty/sessions/*
# but not these files
!kitty/.config/kitty/sessions/example.session
!kitty/.config/kitty/sessions/README.md
!kitty/.config/kitty/sessions/readme.md

# ignore all session other files
/config/kitty/sessions/*

# allow git to traverse dir
!config/kitty/sessions/

# re-include specific files
!config/kitty/sessions/example.session
!config/kitty/sessions/README.md
!config/kitty/sessions/readme.md

/config/kitty/arch.conf

